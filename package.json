{
  "name": "ai-top-sales",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=@ats/api",
    "dev:web": "turbo dev --filter=@ats/web",
    "preview:web": "pnpm --filter @ats/web build && pnpm --filter @ats/web start",
    "dev:worker": "turbo dev --filter=@ats/worker",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @ats/database exec prisma generate",
    "db:migrate": "pnpm --filter @ats/database exec prisma migrate dev",
    "db:migrate:prod": "pnpm --filter @ats/database exec prisma migrate deploy",
    "db:push": "pnpm --filter @ats/database exec prisma db push",
    "db:studio": "pnpm --filter @ats/database exec prisma studio",
    "db:seed": "pnpm --filter @ats/database exec npx tsx prisma/seed.ts",
    "db:seed:demo": "pnpm --filter @ats/database exec npx tsx prisma/seed-demo.ts",
    "set-tenant-settings": "ts-node --project tsconfig.scripts.json scripts/set-tenant-settings.ts",
    "test-persona-switch": "ts-node --project tsconfig.scripts.json scripts/test-persona-switch.ts",
    "test-booking-critical-path": "ts-node --project tsconfig.scripts.json scripts/test-booking-critical-path.ts",
    "phase1-verify": "tsx tests/phase1-verify.ts",
    "kb:backup": "tsx scripts/backup-tenant-kb.ts --tenant-id demo-tenant",
    "kb:restore-missing": "tsx scripts/restore-missing-kb-from-snapshot.ts --tenant-id demo-tenant --snapshot artifacts/demo-tenant-kb-snapshot.json",
    "kb:restore-snapshot": "tsx scripts/restore-tenant-kb-from-snapshot.ts --tenant-id demo-tenant --snapshot artifacts/demo-tenant-kb-snapshot.json --replace",
    "demo:ensure:phase2a": "tsx scripts/ensure-phase2a-demo-tenants.ts",
    "smoke:mvp": "tsx scripts/mvp-smoke.ts",
    "smoke:industries": "tsx scripts/multi-industry-smoke.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "export:demo-kb": "tsx scripts/export-demo-tenant-kb.ts",
    "clean": "turbo clean && rimraf node_modules"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "prettier": "^3.5.3",
    "prisma": "^6.4.1",
    "rimraf": "^6.0.1",
    "turbo": "^2.4.4"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
