# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_top_sales

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth ──
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── OpenAI / AI engine ──
# AI_ENGINE_MODE: rule | llm | auto — unset in code defaults to auto (uses OpenAI when OPENAI_API_KEY is set)
AI_ENGINE_MODE=auto
# Paste your key locally only; never commit real secrets (use .env / .env.local — gitignored)
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
# AI_ENGINE_LLM_TIMEOUT_MS=15000

# ── WhatsApp Cloud API ──
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_VERIFY_TOKEN=my-verify-token

# ── App URLs ──
NEXT_PUBLIC_API_URL=http://localhost:3001
APP_URL=http://localhost:3000
API_PORT=3001
